{
    "name": "pintos-dev",
    "dockerFile": "Dockerfile",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt=seccomp=unconfined"
    ],
    "remoteUser": "jungle",
    "containerEnv": {
        "PINTOS_WORKSPACE": "/workspaces/${localWorkspaceFolderBasename}"
    },
    "remoteEnv": {
        "PINTOS_WORKSPACE": "/workspaces/${localWorkspaceFolderBasename}",
        "PATH": "${containerEnv:PATH}:/workspaces/${localWorkspaceFolderBasename}/pintos/utils"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools",
                "ms-azuretools.vscode-docker",
                "ms-vscode.makefile-tools"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash (login)",
                "terminal.integrated.profiles.linux": {
                    "bash (login)": {
                        "path": "/bin/bash",
                        "args": [
                            "-l"
                        ]
                    }
                }
            }
        }
    }
}
